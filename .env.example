# LogiclemonAI - Content Creator Configuration

# Application
APP_NAME="LogiclemonAI - Content Creator"
APP_VERSION="2.0.0"
DEBUG=false

# OpenAI / OpenRouter
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
HTTP_REFERER=""
X_TITLE="LogiclemonAI"

# Cloudflare Workers
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_DB_URL=""
CLOUDFLARE_RESEARCH_URL=""

# YouTube Data v3 (API key for public reads)
YOUTUBE_API_KEY=""

# YouTube OAuth (desktop app for uploads/analytics)
YT_OAUTH_CLIENT_ID=""
YT_OAUTH_CLIENT_SECRET=""
YT_TOKEN_FILE="yt_token.pickle"

# X (Twitter) integration
X_WORKER_URL=""
X_WORKER_TOKEN=""

# CORS
CORS_ALLOW_ORIGINS="*"

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=3600

# Content Settings
MAX_CONTENT_LENGTH=5000
DEFAULT_QUALITY_THRESHOLD=0.7
