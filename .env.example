# LogiclemonAI - Content Creator Configuration

# Application
APP_NAME="LogiclemonAI - Content Creator"
APP_VERSION="2.0.0"
DEBUG=false

# OpenAI / OpenRouter
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Cloudflare Workers (replaces Supabase + Tavily + Firecrawl)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_DB_URL=""
CLOUDFLARE_RESEARCH_URL=""

# YouTube API (OAuth 2.0)
YT_CLIENT_SECRET_FILE="client_secret.json"
YT_TOKEN_FILE="yt_token.pickle"

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=3600

# Content Settings
MAX_CONTENT_LENGTH=5000
DEFAULT_QUALITY_THRESHOLD=0.7
