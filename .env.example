# LogiclemonAI - Content Creator Configuration

# Application
APP_NAME="LogiclemonAI - Content Creator"
APP_VERSION="2.0.0"
DEBUG=false

# Supabase Database
DATABASE_URL=""
PUBLIC_SUPABASE_URL=""
PUBLIC_SUPABASE_ANON_KEY=""

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# YouTube API (OAuth 2.0)
# Place your client_secret.json from Google Cloud Console in the project root
YT_CLIENT_SECRET_FILE="client_secret.json"
YT_TOKEN_FILE="yt_token.pickle"

# Research APIs (optional but recommended)
TAVILY_API_KEY=""
FIRECRAWL_API_KEY=""

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=3600

# Content Settings
MAX_CONTENT_LENGTH=5000
DEFAULT_QUALITY_THRESHOLD=0.7
